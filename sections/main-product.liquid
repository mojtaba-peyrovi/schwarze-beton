{{ 'section-product.css' | asset_url | stylesheet_tag }}
{{ 'section-homepage.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="hos-pdp" id="MainProduct-{{ section.id }}" data-section="{{ section.id }}">
  <div class="page-width">

    {%- comment -%} ── Breadcrumb ── {%- endcomment -%}
    <nav class="hos-pdp__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">⚔</span>
      {%- if product.collections.size > 0 -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span aria-hidden="true">⚔</span>
      {%- endif -%}
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="hos-pdp__layout">

      {%- comment -%} ── Gallery ── {%- endcomment -%}
      <div class="hos-pdp__gallery">
        <div class="hos-pdp__main-img-wrap">
          {%- assign hero_media = current_variant.featured_media | default: product.featured_media -%}
          {%- if hero_media -%}
            <img
              class="hos-pdp__main-img"
              id="PDPMainImg"
              src="{{ hero_media | image_url: width: 1200 }}"
              alt="{{ hero_media.alt | default: product.title | escape }}"
              width="{{ hero_media.width }}"
              height="{{ hero_media.height }}"
              loading="eager"
              fetchpriority="high"
            >
          {%- else -%}
            <span class="hos-pdp__no-img">No image available</span>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="hos-pdp__thumbnails" id="PDPThumbnails">
            {%- for image in product.images limit: 8 -%}
              <button
                type="button"
                class="hos-pdp__thumb{% if forloop.first %} hos-pdp__thumb--active{% endif %}"
                data-img-url="{{ image | image_url: width: 1200 }}"
                data-img-alt="{{ image.alt | default: product.title | escape }}"
                aria-label="{{ image.alt | default: product.title | escape }}"
              >
                <img
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  width="200"
                  height="200"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Info Panel ── {%- endcomment -%}
      <div class="hos-pdp__info">

        {%- if product.vendor != blank and section.settings.show_vendor -%}
          <p class="hos-pdp__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="hos-pdp__title">{{ product.title }}</h1>

        {%- comment -%} Price {%- endcomment -%}
        <div class="hos-pdp__price" id="PDPPrice">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="hos-pdp__price-compare" id="PDPCompare">{{ current_variant.compare_at_price | money }}</span>
          {%- else -%}
            <span class="hos-pdp__price-compare" id="PDPCompare" style="display:none"></span>
          {%- endif -%}
          <span class="hos-pdp__price-current" id="PDPPriceCurrent">{{ current_variant.price | money }}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="hos-pdp__sale-badge">Sale</span>
          {%- endif -%}
        </div>

        {%- comment -%} Product Form {%- endcomment -%}
        {%- form 'product', product, id: 'PDPForm', class: 'hos-pdp__form', novalidate: 'novalidate' -%}

          {%- unless product.has_only_default_variant -%}

            {%- for option in product.options_with_values -%}
              {%- assign option_lc = option.name | downcase -%}
              {%- assign opt_idx = forloop.index0 -%}

              <div class="hos-pdp__option">
                <span class="hos-pdp__option-label">
                  {{ option.name }}
                  {%- if option_lc == 'size' -%}
                    <button type="button" class="hos-pdp__size-guide" onclick="return false;">Size Guide</button>
                  {%- endif -%}
                </span>

                {%- if option_lc == 'color' or option_lc == 'colour' or option_lc == 'farbe' -%}
                  <div class="hos-pdp__color-swatches" data-option-index="{{ opt_idx }}">
                    {%- for value in option.values -%}
                      {%- assign swatch_color = value | downcase | replace: ' ', '' -%}
                      {%- assign is_sel = false -%}
                      {%- if current_variant.options[opt_idx] == value -%}{%- assign is_sel = true -%}{%- endif -%}
                      <button
                        type="button"
                        class="hos-pdp__color-swatch{% if is_sel %} hos-pdp__color-swatch--selected{% endif %}"
                        data-value="{{ value | escape }}"
                        title="{{ value | escape }}"
                        aria-label="{{ value | escape }}"
                        style="background-color: {{ swatch_color }};"
                      ></button>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <div class="hos-pdp__option-buttons" data-option-index="{{ opt_idx }}">
                    {%- for value in option.values -%}
                      {%- assign is_sel = false -%}
                      {%- if current_variant.options[opt_idx] == value -%}{%- assign is_sel = true -%}{%- endif -%}
                      <button
                        type="button"
                        class="hos-pdp__option-btn{% if is_sel %} hos-pdp__option-btn--selected{% endif %}"
                        data-value="{{ value | escape }}"
                      >{{ value }}</button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}

            <input type="hidden" name="id" id="PDPVariantId" value="{{ current_variant.id }}">

          {%- else -%}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          {%- endunless -%}

          {%- comment -%} Quantity {%- endcomment -%}
          <div class="hos-pdp__qty">
            <span class="hos-pdp__option-label" id="PDPQtyLabel">Quantity</span>
            <div class="hos-pdp__qty-control" role="group" aria-labelledby="PDPQtyLabel">
              <button type="button" class="hos-pdp__qty-btn" data-action="dec" aria-label="Decrease quantity">−</button>
              <input
                class="hos-pdp__qty-input"
                type="number"
                id="PDPQty"
                name="quantity"
                value="1"
                min="1"
                aria-label="Quantity"
              >
              <button type="button" class="hos-pdp__qty-btn" data-action="inc" aria-label="Increase quantity">+</button>
            </div>
          </div>

          {%- comment -%} Add to Cart {%- endcomment -%}
          <div class="hos-pdp__ctas">
            <button
              type="submit"
              name="add"
              class="hos-btn hos-btn--primary hos-pdp__atc"
              id="PDPAtcBtn"
              {%- unless current_variant.available %} disabled aria-disabled="true"{% endunless %}
            >
              {%- if current_variant.available -%}
                In den Warenkorb
              {%- else -%}
                Ausverkauft
              {%- endif -%}
            </button>
          </div>

        {%- endform -%}

        {%- comment -%} Description {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="hos-pdp__desc rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- comment -%} Meta ── {%- endcomment -%}
        <div class="hos-pdp__meta" id="PDPMeta">
          {%- if current_variant.sku != blank -%}
            <p class="hos-pdp__meta-item">
              <span class="hos-pdp__meta-label">SKU</span>
              <span id="PDPSku">{{ current_variant.sku }}</span>
            </p>
          {%- endif -%}
          <p class="hos-pdp__meta-item">
            <span class="hos-pdp__meta-label">Availability</span>
            <span id="PDPAvailability">
              {%- if current_variant.available -%}In stock{%- else -%}Sold out{%- endif -%}
            </span>
          </p>
        </div>

      </div>{%- comment -%} /hos-pdp__info {%- endcomment -%}
    </div>{%- comment -%} /hos-pdp__layout {%- endcomment -%}
  </div>{%- comment -%} /page-width {%- endcomment -%}
</div>

{%- comment -%} ── Serialise variant data for JS ── {%- endcomment -%}
<script id="PDPVariants" type="application/json">
  {{ product.variants | json }}
</script>

<script>
(function () {
  'use strict';

  // ── Thumbnail switcher ──
  var mainImg = document.getElementById('PDPMainImg');
  document.querySelectorAll('.hos-pdp__thumb').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.hos-pdp__thumb').forEach(function (b) {
        b.classList.remove('hos-pdp__thumb--active');
      });
      btn.classList.add('hos-pdp__thumb--active');
      if (mainImg) {
        mainImg.src = btn.dataset.imgUrl;
        mainImg.alt = btn.dataset.imgAlt;
      }
    });
  });

  // ── Variant selection ──
  var variantData = JSON.parse(document.getElementById('PDPVariants').textContent);
  var variantInput = document.getElementById('PDPVariantId');
  if (!variantInput) return; // single-variant product — nothing to do

  var selectedOptions = variantData.find(function (v) {
    return v.id === parseInt(variantInput.value, 10);
  });
  var currentOptions = selectedOptions ? selectedOptions.options.slice() : [];

  document.querySelectorAll('.hos-pdp__option-buttons, .hos-pdp__color-swatches').forEach(function (group) {
    var optionIndex = parseInt(group.dataset.optionIndex, 10);
    var btns = group.querySelectorAll('.hos-pdp__option-btn, .hos-pdp__color-swatch');

    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        btns.forEach(function (b) {
          b.classList.remove('hos-pdp__option-btn--selected', 'hos-pdp__color-swatch--selected');
        });
        btn.classList.add(
          btn.classList.contains('hos-pdp__color-swatch')
            ? 'hos-pdp__color-swatch--selected'
            : 'hos-pdp__option-btn--selected'
        );
        currentOptions[optionIndex] = btn.dataset.value;
        syncVariant();
      });
    });
  });

  function syncVariant() {
    var match = variantData.find(function (v) {
      return v.options.every(function (opt, i) { return opt === currentOptions[i]; });
    });
    if (!match) return;

    variantInput.value = match.id;

    // Price
    var priceEl = document.getElementById('PDPPriceCurrent');
    var compareEl = document.getElementById('PDPCompare');
    if (priceEl) priceEl.textContent = formatMoney(match.price);
    if (compareEl) {
      if (match.compare_at_price && match.compare_at_price > match.price) {
        compareEl.textContent = formatMoney(match.compare_at_price);
        compareEl.style.display = '';
      } else {
        compareEl.style.display = 'none';
      }
    }

    // ATC button
    var atcBtn = document.getElementById('PDPAtcBtn');
    if (atcBtn) {
      atcBtn.disabled = !match.available;
      atcBtn.setAttribute('aria-disabled', !match.available);
      atcBtn.textContent = match.available ? 'In den Warenkorb' : 'Ausverkauft';
    }

    // SKU
    var skuEl = document.getElementById('PDPSku');
    if (skuEl) skuEl.textContent = match.sku || '';

    // Availability
    var availEl = document.getElementById('PDPAvailability');
    if (availEl) availEl.textContent = match.available ? 'In stock' : 'Sold out';

    // Update URL without reload
    if (history.replaceState) {
      var url = new URL(window.location.href);
      url.searchParams.set('variant', match.id);
      history.replaceState({}, '', url.toString());
    }
  }

  // ── Quantity controls ──
  var qtyInput = document.getElementById('PDPQty');
  document.querySelectorAll('.hos-pdp__qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var val = parseInt(qtyInput.value, 10) || 1;
      qtyInput.value = btn.dataset.action === 'inc' ? val + 1 : Math.max(1, val - 1);
    });
  });

  // ── Money formatter ──
  function formatMoney(cents) {
    var formatter = window.Shopify && window.Shopify.formatMoney
      ? function (c) { return window.Shopify.formatMoney(c); }
      : function (c) { return '£' + (c / 100).toFixed(2); };
    return formatter(cents);
  }
})();
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product"
    }
  ]
}
{% endschema %}
