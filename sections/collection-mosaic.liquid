{{ 'section-homepage.css' | asset_url | stylesheet_tag }}

<section class="hos-mosaic" id="section-{{ section.id }}" aria-label="Collections">
  <div class="hos-mosaic__header page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hos-section-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="hos-section-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  <div class="hos-mosaic__grid page-width">
    {%- assign tile_index = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'collection_tile' -%}
        {%- assign tile_index = tile_index | plus: 1 -%}
        {%- assign col = block.settings.collection -%}
        {%- assign tile_class = 'hos-mosaic__tile' -%}
        {%- if tile_index == 1 -%}
          {%- assign tile_class = 'hos-mosaic__tile hos-mosaic__tile--large' -%}
        {%- endif -%}

        <a
          href="{{ col.url | default: '#' }}"
          class="{{ tile_class }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.override_image != blank -%}
            <img
              src="{{ block.settings.override_image | image_url: width: 800 }}"
              alt="{{ block.settings.override_image.alt | default: col.title | escape }}"
              loading="lazy"
              class="hos-mosaic__img"
            >
          {%- elsif col.featured_image != blank -%}
            <img
              src="{{ col.featured_image | image_url: width: 800 }}"
              alt="{{ col.featured_image.alt | default: col.title | escape }}"
              loading="lazy"
              class="hos-mosaic__img"
            >
          {%- else -%}
            <div class="hos-mosaic__placeholder" aria-hidden="true"></div>
          {%- endif -%}

          <div class="hos-mosaic__overlay">
            {%- if block.settings.glyph != blank -%}
              <span class="hos-mosaic__glyph" aria-hidden="true">{{ block.settings.glyph }}</span>
            {%- endif -%}
            <span class="hos-mosaic__name">
              {%- if block.settings.label != blank -%}
                {{ block.settings.label }}
              {%- elsif col != blank -%}
                {{ col.title }}
              {%- else -%}
                {{ 'sections.collection_mosaic.collection_fallback' | t }}
              {%- endif -%}
            </span>
            {%- if col != blank and col.products_count > 0 -%}
              <span class="hos-mosaic__count">{{ 'sections.collection_mosaic.product_count' | t: count: col.products_count }}</span>
            {%- endif -%}
            <span class="hos-mosaic__arrow" aria-hidden="true">→</span>
          </div>
        </a>

      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "HOS Collection Mosaic",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Kategorien"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Dark"
    }
  ],
  "blocks": [
    {
      "type": "collection_tile",
      "name": "Collection tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Override label (optional)"
        },
        {
          "type": "text",
          "id": "glyph",
          "label": "Glyph",
          "default": "⚔"
        },
        {
          "type": "image_picker",
          "id": "override_image",
          "label": "Override image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HOS Collection Mosaic",
      "blocks": [
        { "type": "collection_tile", "settings": { "glyph": "⚔", "label": "Dresses" } },
        { "type": "collection_tile", "settings": { "glyph": "⚜", "label": "Corsets" } },
        { "type": "collection_tile", "settings": { "glyph": "✦", "label": "Accessories" } },
        { "type": "collection_tile", "settings": { "glyph": "◆", "label": "Outerwear" } },
        { "type": "collection_tile", "settings": { "glyph": "†", "label": "Footwear" } }
      ]
    }
  ]
}
{% endschema %}
