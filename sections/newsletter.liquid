{{ 'section-homepage.css' | asset_url | stylesheet_tag }}

<section class="hos-newsletter" id="section-{{ section.id }}" aria-label="Newsletter signup">
  <div class="hos-newsletter__inner page-width">

    <div class="hos-newsletter__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hos-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="hos-section-heading">{{ section.settings.heading | default: 'Join the Dark Circle.' }}</h2>
      {%- if section.settings.subtext != blank -%}
        <p class="hos-newsletter__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="hos-newsletter__form-wrap">
      {%- form 'customer', id: 'hos-newsletter-form', class: 'hos-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <p class="hos-newsletter__success" role="status">
            {{ section.settings.success_message | default: 'Welcome to the dark. You are in.' }}
          </p>
        {%- else -%}
          <div class="hos-newsletter__field-wrap">
            <label for="hos-newsletter-email-{{ section.id }}" class="visually-hidden">
              {{ section.settings.placeholder | default: 'Your email' }}
            </label>
            <input
              type="email"
              name="contact[email]"
              id="hos-newsletter-email-{{ section.id }}"
              class="hos-newsletter__input"
              placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}"
              required
              autocomplete="email"
              aria-required="true"
            >
            <button type="submit" class="hos-btn hos-btn--primary">
              {{ section.settings.button_label | default: 'Einschreiben' }}
            </button>
          </div>
          {%- if form.errors -%}
            <p class="hos-newsletter__error" role="alert">
              {{ form.errors.translated_fields['email'] | capitalize }}
              {{ form.errors.messages['email'] }}
            </p>
          {%- endif -%}
        {%- endif -%}

      {%- endform -%}
      {%- if section.settings.legal_text != blank -%}
        <p class="hos-newsletter__legal">{{ section.settings.legal_text }}</p>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HOS Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Der dunkle Kreis"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Dark Circle."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Sub-text",
      "default": "New drops, dark culture, no spam. Ever."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Einschreiben"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Welcome to the dark. You are in."
    },
    {
      "type": "text",
      "id": "legal_text",
      "label": "Legal / privacy note",
      "default": "By subscribing you agree to our privacy policy. Unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "HOS Newsletter"
    }
  ]
}
{% endschema %}
