{{ 'section-homepage.css' | asset_url | stylesheet_tag }}
{{ 'section-collection.css' | asset_url | stylesheet_tag }}

<section class="hos-col-page" id="section-{{ section.id }}">
  <div class="page-width">
    {%- paginate collection.products by section.settings.products_per_page -%}

    <div class="hos-col-layout">

      {%- comment -%} ── Desktop Sidebar ── {%- endcomment -%}
      <aside class="hos-col-sidebar" aria-label="Filters">
        {%- if section.settings.enable_filtering -%}
          <form id="FacetFiltersForm" action="{{ collection.url }}" method="get">

            <div class="hos-filter-sidebar__header">
              <h2 class="hos-filter-sidebar__title">Filter</h2>
            </div>

            {%- for filter in collection.filters -%}
              {%- assign group_open = false -%}
              {%- if filter.active_values.size > 0 -%}
                {%- assign group_open = true -%}
              {%- elsif filter.type == 'price_range' and filter.min_value.value or filter.max_value.value -%}
                {%- assign group_open = true -%}
              {%- elsif forloop.index <= 3 -%}
                {%- assign group_open = true -%}
              {%- endif -%}

              <div class="hos-filter-group{% if group_open %} hos-filter-group--open{% endif %}">
                <button
                  type="button"
                  class="hos-filter-group__toggle"
                  aria-expanded="{{ group_open }}"
                >
                  <span class="hos-filter-group__label">{{ filter.label }}</span>
                  <span class="hos-filter-group__arrow" aria-hidden="true">▾</span>
                </button>

                <div class="hos-filter-group__body">
                  {%- if filter.type == 'price_range' -%}
                    <div class="hos-filter-price">
                      <input
                        class="hos-filter-price__input"
                        type="number"
                        name="{{ filter.min_value.param_name }}"
                        id="Filter-Price-GTE"
                        value="{{ filter.min_value.value | default: '' }}"
                        placeholder="{{ filter.range_min | money_without_currency }}"
                        min="{{ filter.range_min | money_without_currency }}"
                        max="{{ filter.range_max | money_without_currency }}"
                        inputmode="decimal"
                      >
                      <span class="hos-filter-price__sep">—</span>
                      <input
                        class="hos-filter-price__input"
                        type="number"
                        name="{{ filter.max_value.param_name }}"
                        id="Filter-Price-LTE"
                        value="{{ filter.max_value.value | default: '' }}"
                        placeholder="{{ filter.range_max | money_without_currency }}"
                        min="{{ filter.range_min | money_without_currency }}"
                        max="{{ filter.range_max | money_without_currency }}"
                        inputmode="decimal"
                      >
                    </div>
                    <button class="hos-filter-apply" type="submit">Apply</button>
                  {%- else -%}
                    {%- for value in filter.values -%}
                      <label class="hos-filter-option{% if value.active %} hos-filter-option--active{% endif %}">
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        >
                        <span>{{ value.label }}</span>
                        <span class="hos-filter-count">({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}

            <input type="hidden" name="sort_by" value="{{ collection.sort_by | default: collection.default_sort_by }}">
          </form>
        {%- endif -%}
      </aside>

      {%- comment -%} ── Main Content ── {%- endcomment -%}
      <div class="hos-col-main">

        {%- comment -%} Top Bar {%- endcomment -%}
        <div class="hos-col-topbar">
          <div class="hos-col-topbar__left">
            {%- if section.settings.enable_filtering -%}
              <button
                class="hos-filter-toggle"
                id="FilterToggle"
                type="button"
                aria-expanded="false"
                aria-controls="FilterDrawer"
              >
                <span aria-hidden="true">⚙</span> Filter
              </button>
            {%- endif -%}
            <p class="hos-col-topbar__count">
              {{ collection.products_count }}
              {%- if collection.products_count == 1 -%}&nbsp;product{%- else -%}&nbsp;products{%- endif -%}
            </p>
          </div>

          {%- if section.settings.enable_sorting -%}
            <form id="SortByForm" action="{{ collection.url }}" method="get">
              {%- comment -%} Preserve active filter params in sort form {%- endcomment -%}
              {%- for filter in collection.filters -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value -%}
                    <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">
                  {%- endif -%}
                  {%- if filter.max_value.value -%}
                    <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">
                  {%- endif -%}
                {%- else -%}
                  {%- for value in filter.active_values -%}
                    <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}

              {%- assign current_sort = collection.sort_by | default: collection.default_sort_by -%}
              <select
                name="sort_by"
                id="SortBy"
                class="hos-sort-select"
                aria-label="Sort collection"
              >
                <option value="manual" {% if current_sort == 'manual' %}selected{% endif %}>Featured</option>
                <option value="best-selling" {% if current_sort == 'best-selling' %}selected{% endif %}>Best Selling</option>
                <option value="title-ascending" {% if current_sort == 'title-ascending' %}selected{% endif %}>A – Z</option>
                <option value="title-descending" {% if current_sort == 'title-descending' %}selected{% endif %}>Z – A</option>
                <option value="price-ascending" {% if current_sort == 'price-ascending' %}selected{% endif %}>Price: Low – High</option>
                <option value="price-descending" {% if current_sort == 'price-descending' %}selected{% endif %}>Price: High – Low</option>
                <option value="created-descending" {% if current_sort == 'created-descending' %}selected{% endif %}>Newest</option>
              </select>
            </form>
          {%- endif -%}
        </div>

        {%- comment -%} Active Filter Tags {%- endcomment -%}
        {%- assign active_count = 0 -%}
        {%- for filter in collection.filters -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value or filter.max_value.value -%}
              {%- assign active_count = active_count | plus: 1 -%}
            {%- endif -%}
          {%- else -%}
            {%- assign active_count = active_count | plus: filter.active_values.size -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if active_count > 0 -%}
          <div class="hos-active-filters" role="list" aria-label="Active filters">
            {%- for filter in collection.filters -%}
              {%- if filter.type == 'price_range' -%}
                {%- if filter.min_value.value or filter.max_value.value -%}
                  <a href="{{ filter.url_to_remove }}" class="hos-active-filter-tag" role="listitem">
                    {%- if filter.min_value.value and filter.max_value.value -%}
                      {{ filter.min_value.value | money }} – {{ filter.max_value.value | money }}
                    {%- elsif filter.min_value.value -%}
                      From {{ filter.min_value.value | money }}
                    {%- else -%}
                      Up to {{ filter.max_value.value | money }}
                    {%- endif -%}
                    <span class="hos-active-filter-tag__x" aria-hidden="true">✕</span>
                  </a>
                {%- endif -%}
              {%- else -%}
                {%- for value in filter.active_values -%}
                  <a href="{{ value.url_to_remove }}" class="hos-active-filter-tag" role="listitem">
                    {{ value.label }}
                    <span class="hos-active-filter-tag__x" aria-hidden="true">✕</span>
                  </a>
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
            <a href="{{ collection.url }}" class="hos-clear-filters">Clear all</a>
          </div>
        {%- endif -%}

        {%- comment -%} Product Grid {%- endcomment -%}
        <div class="hos-product-grid">
          {%- for product in collection.products -%}
            <a href="{{ product.url }}" class="hos-product-card">
              <div class="hos-product-card__media">
                {%- if product.featured_image != blank -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
                    class="hos-product-card__img"
                  >
                  {%- if product.images[1] != blank -%}
                    <img
                      src="{{ product.images[1] | image_url: width: 600 }}"
                      alt="{{ product.images[1].alt | default: product.title | escape }}"
                      loading="lazy"
                      width="600"
                      height="{{ 600 | divided_by: product.images[1].aspect_ratio | round }}"
                      class="hos-product-card__img hos-product-card__img--hover"
                      aria-hidden="true"
                    >
                  {%- endif -%}
                {%- else -%}
                  <div class="hos-product-card__placeholder" aria-hidden="true"></div>
                {%- endif -%}

                {%- if product.compare_at_price > product.price -%}
                  <span class="hos-product-card__badge">Sale</span>
                {%- elsif product.tags contains 'new' -%}
                  <span class="hos-product-card__badge hos-product-card__badge--new">Neu</span>
                {%- endif -%}
              </div>

              <div class="hos-product-card__info">
                <h3 class="hos-product-card__title">{{ product.title }}</h3>
                <p class="hos-product-card__price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="hos-product-card__price--compare">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span>{{ product.price | money }}</span>
                </p>
                {%- render 'color-swatch', product: product -%}
              </div>
            </a>
          {%- else -%}
            <p class="hos-empty">No products found. Adjust the filters and try again.</p>
          {%- endfor -%}
        </div>

        {%- comment -%} Pagination {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <nav class="hos-pagination" role="navigation" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="hos-pagination__item" aria-label="Previous page">‹</a>
            {%- else -%}
              <span class="hos-pagination__item hos-pagination__item--disabled" aria-hidden="true">‹</span>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="hos-pagination__item">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="hos-pagination__item hos-pagination__item--active" aria-current="page">{{ part.title }}</span>
              {%- else -%}
                <span class="hos-pagination__ellipsis" aria-hidden="true">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="hos-pagination__item" aria-label="Next page">›</a>
            {%- else -%}
              <span class="hos-pagination__item hos-pagination__item--disabled" aria-hidden="true">›</span>
            {%- endif -%}
          </nav>
        {%- endif -%}

      </div>{%- comment -%} /.hos-col-main {%- endcomment -%}
    </div>{%- comment -%} /.hos-col-layout {%- endcomment -%}

    {%- endpaginate -%}
  </div>{%- comment -%} /.page-width {%- endcomment -%}
</section>

{%- comment -%} ── Mobile Filter Drawer ── {%- endcomment -%}
{%- if section.settings.enable_filtering -%}
  <div
    class="hos-filter-drawer"
    id="FilterDrawer"
    role="dialog"
    aria-label="Filters"
    aria-modal="true"
  >
    <div class="hos-filter-drawer__overlay" id="FilterDrawerOverlay"></div>
    <div class="hos-filter-drawer__panel">
      <div class="hos-filter-drawer__header">
        <span class="hos-filter-drawer__title">Filter</span>
        <button
          class="hos-filter-drawer__close"
          id="FilterDrawerClose"
          aria-label="Close filters"
          type="button"
        >✕</button>
      </div>

      <form action="{{ collection.url }}" method="get" id="FacetFiltersFormMobile">
        {%- for filter in collection.filters -%}
          <div class="hos-filter-group hos-filter-group--open">
            <button type="button" class="hos-filter-group__toggle" aria-expanded="true">
              <span class="hos-filter-group__label">{{ filter.label }}</span>
              <span class="hos-filter-group__arrow" aria-hidden="true">▾</span>
            </button>

            <div class="hos-filter-group__body">
              {%- if filter.type == 'price_range' -%}
                <div class="hos-filter-price">
                  <input
                    class="hos-filter-price__input"
                    type="number"
                    name="{{ filter.min_value.param_name }}"
                    value="{{ filter.min_value.value | default: '' }}"
                    placeholder="{{ filter.range_min | money_without_currency }}"
                    min="{{ filter.range_min | money_without_currency }}"
                    max="{{ filter.range_max | money_without_currency }}"
                    inputmode="decimal"
                  >
                  <span class="hos-filter-price__sep">—</span>
                  <input
                    class="hos-filter-price__input"
                    type="number"
                    name="{{ filter.max_value.param_name }}"
                    value="{{ filter.max_value.value | default: '' }}"
                    placeholder="{{ filter.range_max | money_without_currency }}"
                    min="{{ filter.range_min | money_without_currency }}"
                    max="{{ filter.range_max | money_without_currency }}"
                    inputmode="decimal"
                  >
                </div>
              {%- else -%}
                {%- for value in filter.values -%}
                  <label class="hos-filter-option{% if value.active %} hos-filter-option--active{% endif %}">
                    <input
                      type="checkbox"
                      name="{{ value.param_name }}"
                      value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                      {% if value.count == 0 and value.active == false %}disabled{% endif %}
                    >
                    <span>{{ value.label }}</span>
                    <span class="hos-filter-count">({{ value.count }})</span>
                  </label>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}

        <input type="hidden" name="sort_by" value="{{ collection.sort_by | default: collection.default_sort_by }}">
        <button class="hos-filter-apply" type="submit" style="margin-top: var(--space-md);">Apply Filters</button>
      </form>
    </div>
  </div>
{%- endif -%}

<script>
(function () {
  // ── Filter group accordion ──
  document.querySelectorAll('.hos-filter-group__toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var group = btn.closest('.hos-filter-group');
      var open = group.classList.toggle('hos-filter-group--open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });

  // ── Desktop: auto-submit on checkbox change ──
  var desktopForm = document.getElementById('FacetFiltersForm');
  if (desktopForm) {
    desktopForm.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
      cb.addEventListener('change', function () {
        desktopForm.submit();
      });
    });
  }

  // ── Sort: auto-submit on change ──
  var sortSelect = document.getElementById('SortBy');
  if (sortSelect) {
    sortSelect.addEventListener('change', function () {
      sortSelect.closest('form').submit();
    });
  }

  // ── Mobile drawer ──
  var drawer  = document.getElementById('FilterDrawer');
  var toggle  = document.getElementById('FilterToggle');
  var closeBtn = document.getElementById('FilterDrawerClose');
  var overlay = document.getElementById('FilterDrawerOverlay');

  function openDrawer() {
    if (!drawer) return;
    drawer.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    if (toggle) toggle.setAttribute('aria-expanded', 'true');
    if (closeBtn) closeBtn.focus();
  }

  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.remove('is-open');
    document.body.style.overflow = '';
    if (toggle) toggle.setAttribute('aria-expanded', 'false');
    if (toggle) toggle.focus();
  }

  if (toggle) toggle.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay) overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeDrawer();
  });
})();
</script>

{% schema %}
{
  "name": "HOS Collection Grid",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "Enable filtering"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "Enable sorting"
    }
  ]
}
{% endschema %}
