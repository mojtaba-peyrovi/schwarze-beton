{{ 'section-homepage.css' | asset_url | stylesheet_tag }}

<section class="hos-manifesto" id="section-{{ section.id }}" aria-label="Manifesto">
  <div class="hos-manifesto__watermark" aria-hidden="true">
    <img
      src="{{ 'hos-logo-white-transparent.png' | asset_url }}"
      alt=""
      loading="lazy"
      width="600"
    >
  </div>
  <div class="hos-manifesto__inner page-width">

    <div class="hos-manifesto__quote">
      {%- for block in section.blocks -%}
        {%- if block.type == 'quote_line' -%}
          <p class="hos-manifesto__line" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </p>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="hos-manifesto__body">
      {%- for block in section.blocks -%}
        {%- if block.type == 'paragraph' -%}
          <div class="hos-manifesto__para rte" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>
        {%- endif -%}
      {%- endfor -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'cta' -%}
          <a href="{{ block.settings.url }}" class="hos-btn hos-btn--ghost-light" {{ block.shopify_attributes }}>
            {{ block.settings.label }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HOS Manifesto",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "quote_line",
      "name": "Quote line",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Quote line",
          "default": "Not a trend."
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "Body paragraph",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Paragraph",
          "default": "<p>House of Steam is built for those who never belonged to the mainstream. Berlin-born, darkness-driven.</p>"
        }
      ]
    },
    {
      "type": "cta",
      "name": "CTA link",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button label",
          "default": "Unsere Geschichte"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HOS Manifesto",
      "blocks": [
        { "type": "quote_line", "settings": { "text": "Not a trend." } },
        { "type": "quote_line", "settings": { "text": "A conviction." } },
        {
          "type": "paragraph",
          "settings": {
            "text": "<p>House of Steam is built for those who never belonged to the mainstream. Berlin-born, darkness-driven. Every piece we carry is chosen because it belongs to the Schwarze Szene — not because it sells.</p>"
          }
        },
        { "type": "cta", "settings": { "label": "Unsere Geschichte" } }
      ]
    }
  ]
}
{% endschema %}
