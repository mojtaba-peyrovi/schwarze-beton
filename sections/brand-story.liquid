{{ 'section-homepage.css' | asset_url | stylesheet_tag }}

<section class="hos-brand-story" id="section-{{ section.id }}" aria-label="Brand story">
  <div class="hos-brand-story__inner page-width">

    {%- comment -%} LEFT: copy + stats {%- endcomment -%}
    <div class="hos-brand-story__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hos-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hos-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="hos-brand-story__body rte">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="hos-brand-story__stats">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="hos-brand-story__stat" {{ block.shopify_attributes }}>
                <span class="hos-brand-story__stat-number">{{ block.settings.number }}</span>
                <span class="hos-brand-story__stat-label">{{ block.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="hos-btn hos-btn--primary">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: logo visual with crosshair guides {%- endcomment -%}
    <div class="hos-brand-story__visual" aria-hidden="true">
      <div class="hos-brand-story__bracket hos-brand-story__bracket--tl"></div>
      <div class="hos-brand-story__bracket hos-brand-story__bracket--tr"></div>
      <div class="hos-brand-story__bracket hos-brand-story__bracket--bl"></div>
      <div class="hos-brand-story__bracket hos-brand-story__bracket--br"></div>
      <div class="hos-brand-story__crosshair-h"></div>
      <div class="hos-brand-story__crosshair-v"></div>
      <img
        src="{{ 'hos-logo-white-transparent.png' | asset_url }}"
        alt="{{ shop.name }}"
        width="320"
        loading="lazy"
        class="hos-brand-story__logo"
      >
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HOS Brand Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built from Berlin."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Story copy",
      "default": "<p>House of Steam was born in the shadow of the Berlin Wall — where the dark scene carved its identity from cold concrete and darker impulses. We carry that legacy forward, piece by piece.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / value",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Stat label",
          "default": "Curated pieces"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HOS Brand Story",
      "blocks": [
        { "type": "stat", "settings": { "number": "500+", "label": "Curated pieces" } },
        { "type": "stat", "settings": { "number": "30+", "label": "Brands carried" } },
        { "type": "stat", "settings": { "number": "EU-wide", "label": "Free shipping" } }
      ]
    }
  ]
}
{% endschema %}
