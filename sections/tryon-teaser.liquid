<section class="hos-tryon-teaser">
  <div class="page-width hos-tryon-teaser__inner">
    <p class="hos-section-eyebrow">{{ section.settings.eyebrow | default: 'Die Dunkle Anprobe' }}</p>
    <h2 class="hos-tryon-teaser__heading">{{ section.settings.heading | default: 'Trage es,<br>bevor es deins ist.' }}</h2>
    <p class="hos-tryon-teaser__body">{{ section.settings.body | default: 'Sieh dich selbst in Dunkelheit gehüllt — bevor es vor deiner Tür steht.' }}</p>
    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_url | default: '#' }}"
        class="hos-btn hos-btn--primary"
      >{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
</section>

<style>
.hos-tryon-teaser {
  background: var(--bunker);
  padding: var(--space-xl) 0;
  text-align: center;
  border-top: 1px solid var(--ash);
  border-bottom: 1px solid var(--ash);
}

.hos-tryon-teaser__inner {
  max-width: 720px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
}

.hos-tryon-teaser__heading {
  font-family: var(--font-medieval);
  font-size: clamp(2rem, 4vw, 3.4rem);
  color: var(--parchment);
  line-height: 1.05;
  margin: 0;
}

.hos-tryon-teaser__body {
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--bone);
  line-height: 1.7;
  margin: 0;
  max-width: 520px;
}
</style>

{% schema %}
{
  "name": "Tryon Teaser",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Die Dunkle Anprobe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trage es, bevor es deins ist."
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body text",
      "default": "Sieh dich selbst in Dunkelheit gehüllt — bevor es vor deiner Tür steht."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Jetzt Ausprobieren"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Tryon Teaser"
    }
  ]
}
{% endschema %}
