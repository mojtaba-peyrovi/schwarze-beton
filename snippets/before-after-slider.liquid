{%- comment -%}
  Renders the before/after comparison slider.

  Variables expected (assign before render):
    bac_before_img   — image object (can be blank)
    bac_after_img    — image object (can be blank)
    bac_before_label — string, defaults to 'Vorher'
    bac_after_label  — string, defaults to 'Nachher'
    bac_initial      — number 0–100, defaults to 50
{%- endcomment -%}

{%- assign bac_before_label = bac_before_label | default: 'Vorher' -%}
{%- assign bac_after_label  = bac_after_label  | default: 'Nachher' -%}
{%- assign bac_initial      = bac_initial      | default: 50 -%}

<div class="bac" data-bac>

  {%- if bac_eyebrow != blank -%}
    <p class="bac__eyebrow" aria-hidden="true">{{ bac_eyebrow }}</p>
  {%- endif -%}

  {%- comment -%} ── Before (background) ── {%- endcomment -%}
  <div class="bac__before">
    {%- if bac_before_img != blank -%}
      <img
        src="{{ bac_before_img | image_url: width: 1600 }}"
        alt="{{ bac_before_img.alt | default: bac_before_label | escape }}"
        loading="lazy"
        width="{{ bac_before_img.width }}"
        height="{{ bac_before_img.height }}"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'bac__placeholder' }}
    {%- endif -%}
    <span class="bac__label bac__label--before" aria-hidden="true">
      <span class="bac__bracket bac__bracket--tl"></span>
      {{- bac_before_label -}}
      <span class="bac__bracket bac__bracket--tr"></span>
    </span>
  </div>

  {%- comment -%} ── After (overlay, clipped to right of divider) ── {%- endcomment -%}
  <div class="bac__after">
    {%- if bac_after_img != blank -%}
      <img
        src="{{ bac_after_img | image_url: width: 1600 }}"
        alt="{{ bac_after_img.alt | default: bac_after_label | escape }}"
        loading="lazy"
        width="{{ bac_after_img.width }}"
        height="{{ bac_after_img.height }}"
      >
    {%- else -%}
      {{ 'product-2' | placeholder_svg_tag: 'bac__placeholder' }}
    {%- endif -%}
    <span class="bac__label bac__label--after" aria-hidden="true">
      <span class="bac__bracket bac__bracket--tl"></span>
      {{- bac_after_label -}}
      <span class="bac__bracket bac__bracket--tr"></span>
    </span>
  </div>

  {%- comment -%} ── Divider + handle ── {%- endcomment -%}
  <div class="bac__divider" aria-hidden="true">
    <div class="bac__handle">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false">
        <polyline points="6,4 1,9 6,14"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <polyline points="12,4 17,9 12,14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

  {%- comment -%} ── Accessible range input (keyboard moves the split) ── {%- endcomment -%}
  <input
    class="bac__range"
    type="range"
    min="0"
    max="100"
    value="{{ bac_initial }}"
    step="1"
    aria-label="{{ bac_before_label | escape }} / {{ bac_after_label | escape }} Vergleich"
  >

</div>
