{%- comment -%}
  Self-contained country / currency selector — wraps the localization form itself.
  Renders only when more than one country/market is enabled in Shopify Admin.
  Styled in Cinzel to match HOS brand.

  Usage:
    {% render 'country-selector', position: 'Header' %}

  Accepts:
    - position: unique string to namespace IDs (e.g. 'Header', 'Footer', 'Drawer')
{%- endcomment -%}

{%- if localization.available_countries.size > 1 -%}
  <localization-form>
    {%- form 'localization', id: 'CountryForm-{{ position }}', class: 'hos-country-form' -%}
      <div class="hos-country-selector">
        <h2 class="visually-hidden" id="CountryLabel-{{ position }}">
          {{ 'localization.country_label' | t }}
        </h2>
        {%- render 'country-localization', localPosition: 'Country-{{ position }}' -%}
      </div>
    {%- endform -%}
  </localization-form>
{%- endif -%}

<style>
  /* Trigger button */
  .hos-country-selector .disclosure__button {
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: transparent;
    border: 1px solid rgba(var(--color-foreground), 0.25);
    color: rgb(var(--color-foreground));
    padding: 0.35rem 0.7rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: border-color 0.2s;
    white-space: nowrap;
  }

  .hos-country-selector .disclosure__button:hover {
    border-color: rgba(var(--color-foreground), 0.6);
  }

  .hos-country-selector .disclosure__button svg {
    width: 0.55rem;
    height: 0.55rem;
    flex-shrink: 0;
  }

  /* Dropdown panel — no overflow here, only the list scrolls */
  .hos-country-selector .disclosure__list-wrapper {
    position: absolute;
    z-index: 200;
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.18);
    min-width: 15rem;
  }

  /* Remove search filter entirely */
  .hos-country-selector .country-filter { display: none !important; }

  /* Scrollable country list — cap height here only */
  .hos-country-selector .disclosure__list {
    margin: 0;
    padding: 0.2rem 0;
    max-height: 16rem;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: rgba(var(--color-foreground), 0.18) transparent;
  }

  .hos-country-selector .disclosure__list::-webkit-scrollbar { width: 3px; }
  .hos-country-selector .disclosure__list::-webkit-scrollbar-track { background: transparent; }
  .hos-country-selector .disclosure__list::-webkit-scrollbar-thumb {
    background: rgba(var(--color-foreground), 0.2);
  }

  /* Country list items */
  .hos-country-selector .disclosure__link {
    font-family: 'Cinzel', serif;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.38rem 0.75rem;
    transition: color 0.12s;
  }

  .hos-country-selector .disclosure__link:hover,
  .hos-country-selector .disclosure__link[aria-current='true'] {
    color: rgb(var(--color-base-accent-1, 184, 48, 31));
  }

  .hos-country-selector .disclosure__link svg {
    width: 0.65rem;
    height: 0.65rem;
    flex-shrink: 0;
  }

  /* Always show currency code — Shopify hides it when all markets share one currency */
  .hos-country-selector .localization-form__currency {
    display: inline !important;
    font-size: 0.68rem;
    opacity: 1;
    letter-spacing: 0.08em;
    margin-left: auto;
    white-space: nowrap;
  }
</style>
