{%- liquid
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'

  if request.page_type == 'product'
    assign og_type = 'product'
    assign og_title = product.title | append: ' | House of Steam'
    assign og_description = product.title | append: ' — ' | append: product.description | strip_html | truncate: 100 | append: '. Gothic fashion from Berlin. Free EU shipping. 30-day returns. House of Steam.'
  elsif request.page_type == 'collection'
    assign og_title = collection.title | append: ' | House of Steam — Gothic Fashion Berlin'
    assign og_description = collection.description | default: collection.title | strip_html | truncate: 130 | append: '. Gothic fashion from Berlin. Free EU shipping. 30-day returns. House of Steam.'
  elsif request.page_type == 'article'
    assign og_type = 'article'
    assign og_title = article.title | append: ' | House of Steam'
    assign og_description = article.excerpt_or_content | strip_html | truncate: 155
  elsif request.page_type == 'password'
    assign og_url = request.origin
    assign og_title = shop.name
    assign og_description = shop.description | default: shop.name
  else
    assign og_title = page_title | default: shop.name
    assign og_description = page_description | default: shop.description | default: shop.name
  endif

  assign og_image_url = ''
  if page_image
    assign og_image_url = page_image | image_url: width: 1200
  else
    assign og_image_url = 'hos-logo-dark-bg.png' | asset_url
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | strip_html | escape }}">

{%- if page_image -%}
  <meta property="og:image" content="http:{{ og_image_url }}">
  <meta property="og:image:secure_url" content="https:{{ og_image_url }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{%- else -%}
  <meta property="og:image" content="{{ og_image_url }}">
  <meta property="og:image:secure_url" content="{{ og_image_url }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | strip_html | escape }}">
<meta name="twitter:image" content="{{ og_image_url }}">
